<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">

<style>
  .section-header {
    margin-bottom: 0 !important;
  }

  .header-wrapper {
    background: #000000 !important;
    border-bottom: none !important;
  }

  .header-wrapper .page-width {
    max-width: 100%;
    padding: 0;
    margin: 0;
  }

  .rp-header {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    background: #000000;
  }

  .rp-header__brand {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    flex: 0 0 auto;
  }

  .rp-header__logo-wrap img,
  .rp-header__logo-wrap .header__heading-logo {
    width: 90px;
    height: 90px;
    object-fit: contain;
    display: block;
  }

  .rp-header__title {
    color: #ffffff;
    font-family: "Playfair Display", serif;
    font-size: 3.4rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
  }

  .rp-header__navbox {
    flex: 1;
    background: #ffffff;
    min-height: 58px;
    display: flex;
    align-items: center;
    padding: 0 22px;
    border-radius: 6px;
    overflow: hidden;
    margin: 0 24px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .rp-header__navinner {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 320px;
    align-items: center;
    gap: 20px;
  }

  .rp-header__menu {
    display: flex;
    justify-content: center;
    min-width: 0;
  }

  .rp-header__menu ul {
    display: flex;
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 0;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
  }

  .rp-header__menu a {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 12px;
    text-decoration: none;
    color: #111111;
    font-size: 1.3rem;
    font-family: "Playfair Display", serif;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: all 0.25s ease;
  }

  .rp-header__menu a::after {
    content: "";
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 6px;
    height: 1px;
    background: #111111;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .rp-header__menu a:hover::after {
    transform: scaleX(1);
  }

  .rp-header__search {
    display: flex;
    justify-content: flex-end;
    min-width: 0;
  }

  .rp-header__search form {
    position: relative;
    width: 100%;
    max-width: 320px;
    height: 40px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 999px;
    background: #f7f7f7;
    transition: all 0.25s ease;
    box-sizing: border-box;
  }

  .rp-header__search form:focus-within {
    background: #ffffff;
    border-color: rgba(0, 0, 0, 0.3);
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.06);
  }

  .rp-header__search input {
    width: 100%;
    height: 100%;
    border: none;
    outline: none;
    padding: 0 46px 0 14px;
    font-size: 1.3rem;
    font-family: "Playfair Display", serif;
    background: transparent;
    color: #111111;
    box-sizing: border-box;
  }

  .rp-header__search input::placeholder {
    color: rgba(17, 17, 17, 0.55);
  }

  .rp-header__search button {
    position: absolute;
    top: 50%;
    right: 14px;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    padding: 0;
    margin: 0;
    line-height: 0;
  }

  .rp-header__search button svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .rp-mobile-header {
    display: none;
  }

  @media screen and (max-width: 1100px) {
    .rp-header__title {
      font-size: 2.8rem;
    }

    .rp-header__logo-wrap img,
    .rp-header__logo-wrap .header__heading-logo {
      width: 72px;
      height: 72px;
    }

    .rp-header__menu ul {
      gap: 8px;
    }

    .rp-header__menu a {
      font-size: 1.18rem;
      padding: 0 10px;
    }

    .rp-header__navinner {
      grid-template-columns: 1fr 280px;
      gap: 12px;
    }

    .rp-header__navbox {
      margin: 0 16px;
    }

    .rp-header__search form {
      max-width: 280px;
    }
  }

  @media screen and (max-width: 989px) {
    .rp-header {
      display: none;
    }

    .rp-mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px;
      background: #000000;
      gap: 10px;
    }

    .rp-mobile-header__center {
      flex: 1;
      display: flex;
      justify-content: center;
      min-width: 0;
    }

    .rp-mobile-header__title {
      color: #ffffff;
      font-family: "Playfair Display", serif;
      font-size: 2rem;
      font-weight: 600;
      white-space: nowrap;
    }

    .rp-mobile-header__right {
      display: none !important;
    }
  }
</style>

<div class="header-wrapper">
  <header class="page-width">

    <div class="rp-header">
      <a href="{{ routes.root_url }}" class="rp-header__brand">
        {% if settings.logo != blank %}
          <span class="rp-header__logo-wrap">
            {% assign logo_alt = settings.logo.alt | default: shop.name | escape %}
            {% assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio %}
            {{
              settings.logo
              | image_url: width: 300
              | image_tag:
                class: 'header__heading-logo motion-reduce',
                widths: '120, 180, 240, 300',
                width: settings.logo_width,
                height: logo_height,
                alt: logo_alt,
                preload: true
            }}
          </span>
        {% endif %}
        <span class="rp-header__title">{{ shop.name }}</span>
      </a>

      <div class="rp-header__navbox">
        <div class="rp-header__navinner">
          <div class="rp-header__menu">
            <ul>
              <li><a href="{{ routes.root_url }}">Inicio</a></li>
              <li><a href="/collections/all">Catálogo</a></li>
              <li><a href="/collections/promociones">Promociones</a></li>
              <li><a href="/pages/sobre-nosotros">Sobre nosotros</a></li>
            </ul>
          </div>

          <div class="rp-header__search">
            <form action="{{ routes.search_url }}" method="get" role="search">
              <input
                type="search"
                name="q"
                value="{{ search.terms | escape }}"
                placeholder="Buscar relojes, marcas y colecciones"
                autocomplete="off"
              >
              <input type="hidden" name="options[prefix]" value="last">
              <button type="submit" aria-label="Buscar en la tienda">
                <svg viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="5.25" stroke="currentColor" stroke-width="1.5" />
                  <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="rp-mobile-header">
      <div>
        {% render 'header-drawer' %}
      </div>

      <div class="rp-mobile-header__center">
        <span class="rp-mobile-header__title">{{ shop.name }}</span>
      </div>
    </div>

  </header>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "Menu color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}