{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

<div class="collection-hero color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-custom">
    
    <div class="collection-hero__inner page-width">
      <div class="custom-banner">
        <div class="custom-banner__text">
          
          <div class="custom-banner__breadcrumb">
            <span class="crumb"><a href="/">Inicio</a></span>
            <span class="separator">/</span>
            <span class="crumb"><a href="/collections/all">Catalogo</a></span>
            <span class="separator">/</span>
            {% unless collection.handle == 'all' %}
              <span class="crumb active">{{ collection.title }}</span>
            {% endunless %}
          </div>
    
          <p class="custom-banner__subtitle">
            relojes con la mejor calidad del mercado
          </p>
          
        </div>
      </div>
    </div>

    <div class="hero-custom__image">

      <img
        class="watch-small"
        src="{{ 'icon-reloj2.png' | asset_url }}"
        alt="Reloj pequeño"
        width="800"
        height="800"
        loading="lazy"
      >

      <img
        class="watch-big"
        src="{{ 'icon-reloj.svg' | asset_url }}"
        alt="Reloj grande"
        width="800"
        height="800"
        loading="lazy"
      >

    </div>

  </div>
</div>

<style>
/* ===== FONDO GENERAL ===== */
.hero-custom {
  width: 100%;
  min-height: 198px; /* Altura suficiente para que el reloj no se vea apretado */
  background:
    radial-gradient(circle at 75% 50%, rgba(255,255,255,0.08), transparent 60%),
    linear-gradient(
      120deg,
      #f1f1f1 55%,
      #000000 55%,
      #111111 65%,
      #242424 80%,
      #3a3a3a 100%
    );
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 0px 5%
}

.collection-hero__inner {
  width: 100%;
}

/* ===== TEXTO Y CONTENEDOR ===== */
.custom-banner {
  display: flex;
  align-items: center;
  z-index: 2;
  position: relative;
}

.custom-banner__text {
  max-width: 550px; /* Aumentado para que el texto no se rompa en tantas líneas */
  padding: 20px 0;
}

.custom-banner__breadcrumb {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.custom-banner__breadcrumb a, 
.separator {
  text-decoration: none;
  color: #333;
  font-size: 18px;
}



.crumb.active {
  font-size: 32px;
  font-weight: 700;
  color: #000;
  margin-left: 5px;
}

.custom-banner__subtitle {
  font-size: 28px;
  color: #000;
  line-height: 1.2;
  margin: 0;
  font-weight: 400;
}

/* ===== IMAGEN DEL RELOJ (DERECHA) ===== */
.hero-custom__image {
  position: absolute;
  right: 3%;
  top: 60%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  gap: 0px;
  z-index: 5;
}

.hero-custom__image img {
  width: 250px;  /* 🔥 tamaño fijo igual para ambos */
  object-fit: contain;
  filter: drop-shadow(-15px 10px 25px rgba(0,0,0,0.5));
}

/* ===== RESPONSIVE ===== */

/* TABLET / PANTALLAS MEDIANAS */
@media screen and (max-width: 990px) {
  .hero-custom {
    flex-direction: column;
    padding: 40px 0;
    min-height: auto;
    background: #f1f1f1;
     gap:8px;
  }

  .custom-banner__text {
    max-width: 100%;
    text-align: center;
    padding: 0 20px;
  }

  .custom-banner__breadcrumb {
    justify-content: center;
  }

  /* Bajamos el z-index para que no tape los menús de Shopify */
  .hero-custom__image {
    position: relative;
    width: 50%;
    right: auto;
    top: auto;
    transform: none;
    margin: 20px auto 0;
    z-index: 1; 
  }
  .hero-custom__image img {
    width: 140px;
  }
}

/* MÓVILES (Android/iOS) */
@media screen and (max-width: 480px) {
  .hero-custom {
    /* Degradado vertical para móvil */
    background: linear-gradient(180deg, #f1f1f1 55%, #000000 100%);
    padding: 30px 0;
    gap: 8px;
  }

  .custom-banner__subtitle { 
    font-size: 20px; 
  }

  .crumb.active { 
    font-size: 24px; 
  }

  .hero-custom__image { 
    width: 70%; 
    z-index: 1; /* Valor bajo para que el menú pase por encima */
  }

  .hero-custom__image img {
    width: 140px;
  }
  
  /* TRUCO EXTRA: Si el menú de Shopify se abre, ocultamos el reloj 
     para que no estorbe la lectura del catálogo */
  .menu-opening .hero-custom__image {
    display: none;
  }
}
</style>
