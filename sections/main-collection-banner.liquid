{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{% if collection.handle == 'promociones' %}

<!-- SOLO PROMOCIONES -->
<div class="collection-hero gradient">
  <div class="hero-custom promo-clean">
    <div class="collection-hero__inner page-width">
      <div class="custom-banner">
        <div class="custom-banner__text">

          <h1 class="promo-title">
            {{ collection.title | upcase }}
          </h1>

          <p class="promo-subtitle">
            Relojes con la mejor calidad del mercado
          </p>

        </div>
      </div>
    </div>
  </div>
</div>

<style>
.promo-clean {
  background: #f6f6f6;
  justify-content: center;
  padding: 50px 20px;
}

.promo-clean .custom-banner {
  width: 100%;
  justify-content: center;
  text-align: center;
}

.promo-clean .custom-banner__text {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
}

.promo-title {
  font-family: inherit;
  font-size: 64px;
  font-weight: 500;
  text-transform: uppercase;
  color: #b07a2a;
  margin: 0 0 12px;
  letter-spacing: 0.08em;
  text-align: center;
  line-height: 1;
}

.promo-subtitle {
  font-family: inherit;
  font-size: 28px;
  color: #111111;
  margin: 0;
  font-weight: 400;
  text-align: center;
  line-height: 1.25;
}

@media screen and (max-width: 749px) {
  .promo-title {
    font-size: 34px;
  }

  .promo-subtitle {
    font-size: 18px;
  }
}
</style>

{% else %}

<!-- RESTO DEL SITIO -->
<div class="collection-hero color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-custom">
    
    <div class="collection-hero__inner page-width">
      <div class="custom-banner">
        <div class="custom-banner__text">
          
          <div class="custom-banner__breadcrumb">
            <span class="crumb"><a href="/">Inicio</a></span>
            <span class="separator">/</span>

            {% if collection.handle == 'all' %}
              <span class="crumb active">Catálogo</span>
            {% else %}
              <span class="crumb"><a href="/collections/all">Catálogo</a></span>
            {% endif %}

            {% unless collection.handle == 'all' %}
              <span class="separator">/</span>
              <span class="crumb active">{{ collection.title }}</span>
            {% endunless %}
          </div>
    
          <p class="custom-banner__subtitle">
            Relojes con la mejor calidad del mercado
          </p>
          
        </div>
      </div>
    </div>

    <div class="hero-custom__image">
      <img
        class="watch-small"
        src="{{ 'icon-reloj2.png' | asset_url }}"
        alt="Reloj azul"
        width="800"
        height="800"
        loading="lazy"
      >

      <img
        class="watch-big"
        src="{{ 'icon-reloj.svg' | asset_url }}"
        alt="Reloj negro"
        width="800"
        height="800"
        loading="lazy"
      >
    </div>
  </div>
</div>

<style>
.hero-custom {
  width: 100%;
  min-height: 198px;
  background:
    radial-gradient(circle at 75% 50%, rgba(255,255,255,0.08), transparent 60%),
    linear-gradient(
      120deg,
      #f1f1f1 55%,
      #000000 55%,
      #111111 65%,
      #242424 80%,
      #3a3a3a 100%
    );
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 0 5%;
}

.collection-hero__inner {
  width: 100%;
}

.custom-banner {
  display: flex;
  align-items: center;
  z-index: 2;
  position: relative;
}

.custom-banner__text {
  max-width: 550px;
  padding: 20px 0;
}

.custom-banner__breadcrumb {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.custom-banner__breadcrumb a,
.custom-banner__breadcrumb .separator {
  text-decoration: none;
  color: #333;
  font-size: 18px;
}

.custom-banner__breadcrumb .crumb.active {
  font-size: 32px;
  font-weight: 700;
  color: #000;
  margin-left: 5px;
  white-space: nowrap;
}

.custom-banner__subtitle {
  font-size: 28px;
  color: #000;
  line-height: 1.2;
  margin: 0;
  font-weight: 400;
}

/* CONTENEDOR DE RELOJES */
.hero-custom__image {
  position: absolute;
  right: 3%;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  z-index: 5;
  overflow: visible;
}

/* BASE IMÁGENES */
.hero-custom__image img {
  width: 250px;
  min-width: 250px;
  max-width: 250px;
  height: auto;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
  filter: drop-shadow(-15px 10px 25px rgba(0,0,0,0.5));
}

.watch-small {
    width: 250px !important;
    min-width: 250px !important;
    max-width: 250px !important;
    transform: translateY(0px) scale(1.42) !important;
    transform-origin: center center !important;
  }
.watch-big {
    width: 250px !important;
    min-width: 250px !important;
    max-width: 250px !important;
    transform: translateY(18px) scale(1.42) !important;
    transform-origin: center center !important;
  }
/* SVG NEGRO: tamaño visual real */
.watch-big {
  transform: translateY(0) scale(1);
  transform-origin: center center;
}

/* ===== BREADCRUMB RESPONSIVE ===== */
@media screen and (max-width: 520px) {
  .custom-banner__breadcrumb {
    flex-wrap: nowrap;
    width: 100%;
    overflow: hidden;
    white-space: nowrap;
  }

  .custom-banner__breadcrumb a,
  .custom-banner__breadcrumb .separator {
    font-size: clamp(12px, 3.5vw, 16px);
  }

  .custom-banner__breadcrumb .crumb.active {
    font-size: clamp(14px, 4.5vw, 20px);
    margin-left: 0;
  }
}

/* ===== DESDE 1145px HACIA ABAJO, LA PARTE DERECHA PASA A GRIS ===== */
@media screen and (max-width: 1145px) {
  .hero-custom {
    background:
      radial-gradient(circle at 75% 50%, rgba(255,255,255,0.08), transparent 60%),
      linear-gradient(
        120deg,
        #f1f1f1 55%,
        #d9d9d9 55%,
        #d3d3d3 65%,
        #c9c9c9 80%,
        #bebebe 100%
      );
  }
}

/* ===== DESDE 1075px: se oculta el azul y se agranda visualmente el negro ===== */
@media screen and (max-width: 1100px) {
  .watch-small {
    display: none !important;
  }

  .hero-custom__image {
    right: 3%;
    top: 50% !important;
    transform: translateY(-50%) !important;
  }

  .watch-big {
    width: 250px !important;
    min-width: 250px !important;
    max-width: 250px !important;
    transform: translateY(18px) scale(1.42) !important;
    transform-origin: center center !important;
  }
}

/* ===== DESDE 910px: mantenerlo grande, sin moverlo ===== */
@media screen and (max-width: 910px) {
  .hero-custom {
    min-height: 185px;
    padding: 0 4%;
  }

  .custom-banner__text {
    max-width: 500px;
  }

  .hero-custom__image {
    right: 3% !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
  }

  .watch-big {
    width: 250px !important;
    min-width: 250px !important;
    max-width: 250px !important;
    transform: translateY(18px) scale(1.42) !important;
  }
}

/* ===== DESDE 820px: un poco menos grande para que no invada el texto ===== */
@media screen and (max-width: 820px) {
  .hero-custom__image {
    right: 2% !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
  }

  .watch-big {
    transform: translateY(14px) scale(1.30) !important;
  }
}

/* ===== DESDE 749px: desaparece el reloj negro ===== */
@media screen and (max-width: 749px) {
  .watch-big {
    display: none !important;
  }

  .hero-custom {
    min-height: 170px;
    padding: 0 30px;
  }

  .custom-banner__text {
    max-width: 100%;
  }

  .custom-banner__subtitle {
    font-size: 20px;
  }
}
</style>

{% endif %}