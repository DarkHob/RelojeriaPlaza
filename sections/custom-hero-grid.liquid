<section class="brands-section page-width">

{% for block in section.blocks %}

<div class="brand-group">

<h2 class="brand-title">
{{ block.settings.brand_title }}
</h2>

<div class="brand-grid">

{% for i in (1..4) %}

{% assign image = 'image_' | append: i %}
{% assign title = 'title_' | append: i %}
{% assign price = 'price_' | append: i %}

<div class="watch-card">

{% if block.settings[image] %}
<img
src="{{ block.settings[image] | image_url: width: 600 }}"
alt="{{ block.settings[title] }}"
width="{{ block.settings[image].width }}"
height="{{ block.settings[image].height }}"
loading="lazy"
>
{% endif %}

<div class="watch-info">

<div class="watch-title">
{{ block.settings[title] }}
</div>

<div class="watch-price">
{{ block.settings[price] }}
</div>

</div>

</div>

{% endfor %}

</div>

</div>

{% endfor %}

</section>


<style>

.brands-section{
margin-top:40px;
width:100%;
}

.brand-group{
margin-bottom:50px;
}

.brand-title{
font-size:14px;
font-weight:700;
letter-spacing:1px;
text-transform:uppercase;
margin-bottom:18px;
}

.brand-grid{
display:grid;
grid-template-columns:repeat(4,minmax(0,1fr));
gap:20px;
width:100%;
}

.watch-card{
display:flex;
flex-direction:column;
height:100%;
transition:transform .2s ease;
}

.watch-card:hover{
transform:translateY(-4px);
}

.watch-card img{
width:100%;
height:220px;
object-fit:cover;
display:block;
background:#f5f5f5;
border-radius:4px;
}

.watch-info{
margin-top:10px;
font-size:13px;
line-height:1.3;
}

.watch-title{
font-weight:600;
text-transform:uppercase;
font-size:13px;
}

.watch-price{
color:#333;
font-size:13px;
}

@media screen and (max-width:990px){

.brand-grid{
grid-template-columns:repeat(2,1fr);
gap:16px;
}

.watch-card img{
height:180px;
}

}

@media screen and (max-width:480px){

.brand-grid{
grid-template-columns:repeat(2,1fr);
gap:12px;
}

.watch-card img{
height:150px;
}

.brand-title{
font-size:13px;
}

.watch-title{
font-size:12px;
}

.watch-price{
font-size:12px;
}

}

</style>


